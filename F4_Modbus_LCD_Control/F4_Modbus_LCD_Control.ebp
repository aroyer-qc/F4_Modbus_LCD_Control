			<Add option="-fno-use-cxa-atexit" />
			<Add option="-Wno-register" />
		</Cpp>
		<Assembler>
			<Add option="-Wa,-ahls=$objects_output_dir\$file_name.lst" />
			<Add option="-Wa,--gdwarf-2" />
			<Add option="-save-temps" />
		</Assembler>
		<Linker>
			<Add option="-eb_lib=n" />

	<Project>
		<Option title="F4_Modbus_LCD_Control" />
		<Option compiler="armgcc_eb" />
		<Build>
			<Target title="Debug LCD Control">
				<Option output="bin\Debug\F4_Modbus_LCD_Control.elf" />
				<Option object_output="obj\Debug\" />
				<Option type="0" />
				<Option create_hex="1" />
				<Option compiler="armgcc_eb" />
				<Option projectDeviceOptionsRelation="0" />
				<Compiler>
					<Add option="-std=gnu11" />
					<Add option="-Wcomment" />
					<Add option="-Wall" />
					<Add option="-fshort-enums" />
					<Add option="-ffunction-sections" />
					<Add option="-O0" />
					<Add option="-g2" />
					<Add symbol="DEBUG" />
					<Add symbol="STM32F437xx" />
				</Compiler>
				<Cpp>
					<Add option="-mfloat-abi=hard" />
					<Add option="-std=gnu++11" />
					<Add option="-Wcomment" />
					<Add option="-pedantic-errors" />
					<Add option="-Wall" />
					<Add option="-fdata-sections" />
					<Add option="-ffunction-sections" />
					<Add option="-g3" />
				</Cpp>
				<Assembler>
					<Add option="-Wa,--gdwarf-2" />
				</Assembler>
				<Linker>
					<Add option="-Wl,--cref" />
				</Linker>
			</Target>
			<Target title="Release LCD Control">
				<Option output="bin\Release\F4_Modbus_LCD_Control.elf" />
				<Option object_output="obj\Release\" />
				<Option type="0" />
				<Option create_hex="1" />
				<Option compiler="armgcc_eb" />
				<Option projectDeviceOptionsRelation="0" />
				<Compiler>
					<Add option="-fdata-sections" />
					<Add option="-ffunction-sections" />
					<Add option="-O2" />
					<Add option="-g2" />
					<Add symbol="STM32F437xx" />
				</Compiler>
				<Assembler>
					<Add option="-Wa,--no-warn" />
				</Assembler>
				<Linker>
					<Add option="-Wl,--gc-sections" />
				</Linker>
			</Target>
		</Build>
		<Device>
			<Add option="$device=cortex-m4" />
			<Add option="$fpu=fpv4-sp-d16" />
			<Add option="$lscript=./../stm32f437vg_flash.ld" />
			<Add option="$stack=0x0300" />
			<Add option="$heap=0x2000" />
		</Device>
		<Compiler>
			<Add option="-mfloat-abi=hard" />
			<Add option="-std=gnu11" />
			<Add option="-O0" />
			<Add option="-g3" />
